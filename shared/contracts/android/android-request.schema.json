{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "android/android-request.schema.json",
  "title": "AndroidRequest",
  "description": "Android 접근성 서비스 분석 요청",
  "type": "object",
  "properties": {
    "timestamp": {
      "type": "integer",
      "minimum": 0,
      "description": "Unix timestamp (초)"
    },
    "sensitivity": {
      "type": ["integer", "null"],
      "minimum": 0,
      "maximum": 100,
      "description": "필터 민감도. 0은 Android 분석에서도 차단하지 않음"
    },
    "comments": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "commentText": {
            "type": "string",
            "description": "댓글 텍스트"
          },
          "author_id": {
            "type": ["string", "null"],
            "description": "작성자 ID (nullable)"
          },
          "boundsInScreen": {
            "$ref": "bounds-in-screen.schema.json"
          }
        },
        "required": ["commentText", "boundsInScreen"],
        "additionalProperties": false
      },
      "minItems": 1,
      "description": "댓글 목록"
    }
  },
  "required": ["timestamp", "comments"],
  "additionalProperties": false
}
