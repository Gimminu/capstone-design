{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "android/bounds-in-screen.schema.json",
  "title": "BoundsInScreen",
  "description": "Android 화면 좌표 (오버레이 위치 지정용)",
  "type": "object",
  "properties": {
    "top": {
      "type": "integer",
      "minimum": 0,
      "description": "상단 좌표 (px)"
    },
    "bottom": {
      "type": "integer",
      "minimum": 0,
      "description": "하단 좌표 (px)"
    },
    "left": {
      "type": "integer",
      "minimum": 0,
      "description": "좌측 좌표 (px)"
    },
    "right": {
      "type": "integer",
      "minimum": 0,
      "description": "우측 좌표 (px)"
    }
  },
  "required": ["top", "bottom", "left", "right"],
  "additionalProperties": false
}
