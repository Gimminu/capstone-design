{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "common/scores.schema.json",
  "title": "Scores",
  "description": "유해성 점수 (0.0 ~ 1.0)",
  "type": "object",
  "properties": {
    "profanity": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "욕설 확률"
    },
    "toxicity": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "독성 확률"
    },
    "hate": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "혐오 표현 확률"
    }
  },
  "required": ["profanity", "toxicity", "hate"],
  "additionalProperties": false
}
